<Project>

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>

        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <AnalysisLevel>latest-recommended</AnalysisLevel>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>

        <Authors>Adam Salisbury</Authors>
        <Company>Smolla</Company>
        <Product>Smolla Presentations</Product>
        <NeutralLanguage>en-GB</NeutralLanguage>
        <Copyright>Copyright (c) Adam Salisbury</Copyright>

        <!-- Managed by release-please. Do not edit by hand. -->
        <Version>0.1.0</Version>

        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);CS1591;CA1848;CA1873;CA2007;CA1305;CA1861</NoWarn>
    </PropertyGroup>

</Project>
